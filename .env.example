# ── Weaviate 配置 ──────────────────────────────────────────────────
WEAVIATE_URL=
WEAVIATE_HOST=localhost
WEAVIATE_SCHEME=http
WEAVIATE_PORT=8080
WEAVIATE_CLASS=EchoDoc
WEAVIATE_API_KEY=

# ── 七牛云配置 ────────────────────────────────────────────────────
QINIU_BASE_URL=
QINIU_ALLOWED_SUBDOMAINS=

# ── MySQL 数据库配置 ──────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=echo_ai

# ── LLM 小模型配置（快速前缀生成） ─────────────────────────────────
SMALL_LLM_BASE_URL=https://api.siliconflow.cn/v1
SMALL_LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
SMALL_LLM_API_KEY=
SMALL_LLM_MAX_TOKENS=64
SMALL_LLM_TEMPERATURE=0.7

# ── LLM 大模型配置（深度续写 + 记忆整合） ──────────────────────────
LARGE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LARGE_LLM_MODEL=qwen3.5-plus
LARGE_LLM_API_KEY=
LARGE_LLM_MAX_TOKENS=2048
LARGE_LLM_TEMPERATURE=0.7

# ── Embedding 配置 ────────────────────────────────────────────────
EMBEDDING_MODEL_NAME=OFA-Sys/chinese-clip-vit-base-patch16
EMBEDDING_DEVICE=auto
EMBEDDING_DIM=512
EMBEDDING_BATCH_SIZE=8
EMBEDDING_CHUNK_SIZE=256
EMBEDDING_CHUNK_OVERLAP=32
EMBEDDING_WARMUP_ON_START=true

# ── 入库配置 ──────────────────────────────────────────────────────
INGEST_MAX_DOWNLOAD_BYTES=52428800
INGEST_DOWNLOAD_TIMEOUT_SECONDS=60
INGEST_DOWNLOAD_RETRIES=3
INGEST_ENABLE_CHUNKING=true
INGEST_CACHE_TTL_SECONDS=600
INGEST_CACHE_MAXSIZE=1024

# ── 记忆系统配置 ──────────────────────────────────────────────────
MEMORY_L0_MAX_COUNT=20
MEMORY_L0_MIN_IMPORTANCE=0.8
MEMORY_L1_MAX_COUNT=100
MEMORY_L1_MIN_IMPORTANCE=0.5
MEMORY_L2_MAX_COUNT=500
MEMORY_DEDUP_THRESHOLD=0.92
MEMORY_MERGE_THRESHOLD=0.85
MEMORY_CONTRADICTION_THRESHOLD=0.80
MEMORY_MAX_SUMMARY_LENGTH=500
MEMORY_MAX_SUMMARIES=50

# ── 多模态 Embedding 配置 ─────────────────────────────────────────
# BGE-M3 文本 Embedding（768维）
BGE_M3_MODEL_NAME=BAAI/bge-m3
BGE_M3_DIM=768
BGE_M3_BATCH_SIZE=8
BGE_M3_DEVICE=auto

# CLIP 图片 Embedding
CLIP_MODEL_NAME=OFA-Sys/chinese-clip-vit-base-patch16
CLIP_DIM=512
CLIP_DEVICE=auto

# Whisper 音频转录 + 声纹嵌入
WHISPER_MODEL_NAME=openai/whisper-small
WHISPER_DEVICE=auto
WHISPER_LANGUAGE=zh

# VideoMAE 视频 Embedding
VIDEO_MAE_MODEL_NAME=MCG-NJU/videomae-base
VIDEO_MAE_DEVICE=auto
VIDEO_MAE_FRAME_SAMPLE_RATE=10
VIDEO_MAE_MAX_FRAMES=16

# ── 检索配置 ──────────────────────────────────────────────────────
VECTOR_SIMILARITY_THRESHOLD=0.7